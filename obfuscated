        end)
        if ok and titleLabel.FontFace and titleLabel.FontFace.Family ~= "Legacy" then break end
    end
    titleLabel.Text = ""
    task.spawn(function()
        task.wait(0.15)
        if not titleLabel or not titleLabel.Parent then return end
        titleLabel.Text = ""
        local function firstNChars(s, n)
            local endByte = utf8.offset(s, n + 1)
            return s:sub(1, endByte and (endByte - 1) or #s)
        end
        local charCount = utf8.len(full)
        local function blinkCursor(baseText, duration)
            local deadline = tick() + duration
            local showUnderscore = true
            while tick() < deadline and titleLabel and titleLabel.Parent do
                titleLabel.Text = baseText .. (showUnderscore and "_" or " ")
                showUnderscore = not showUnderscore
                task.wait(0.2)
            end
            if titleLabel and titleLabel.Parent then titleLabel.Text = baseText .. "_" end
        end
        while titleLabel and titleLabel.Parent do
            -- Type out one UTF-8 character at a time (no partial bytes = no ?)
            for i = 1, charCount do
                if not titleLabel or not titleLabel.Parent then break end
                local base = firstNChars(full, i)
                blinkCursor(base, 0.55)
            end
            if not titleLabel or not titleLabel.Parent then break end
            -- Wait 4 seconds with blinking cursor
            blinkCursor(full, 4)
            if not titleLabel or not titleLabel.Parent then break end
            -- Delete one character at a time with blinking cursor
            for i = charCount, 1, -1 do
                if not titleLabel or not titleLabel.Parent then break end
                local base = firstNChars(full, i - 1)
                blinkCursor(base, 0.55)
            end
            if titleLabel and titleLabel.Parent then titleLabel.Text = "" end
            task.wait(0.6)
        end
    end)
