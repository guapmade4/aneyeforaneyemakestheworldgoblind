-- Stack tower: noclip through objects, but snap to ground (don't go through floor)
local StackPlaceDistance = 60
local StackSphereBaseColor = Color3.fromRGB(115, 147, 179)
local StackSphereFlashWhite = Color3.fromRGB(255, 255, 255)

RunService.RenderStepped:Connect(function()
    if StackEnabled then
        if not StackSphere then
            StackSphere = Instance.new("Part")
            StackSphere.Shape = Enum.PartType.Ball
            StackSphere.Size = Vector3.new(1.5, 1.5, 1.5)
            StackSphere.Color = StackSphereBaseColor
            StackSphere.Transparency = 0.5
            StackSphere.Anchored = true
            StackSphere.CanCollide = false
            StackSphere.Material = Enum.Material.Neon
            StackSphere.Parent = workspace
            mouse.TargetFilter = StackSphere
        end
        -- flashing white <-> 115, 147, 179
        local t = math.sin(tick() * 4) * 0.5 + 0.5
        StackSphere.Color = StackSphereBaseColor:Lerp(StackSphereFlashWhite, t)
        local cam = workspace.CurrentCamera
        if cam then
            local origin, direction = cam:ScreenPointToRay(mouse.X, mouse.Y)
            if origin and direction then
                local noclipPos = origin + direction.Unit * StackPlaceDistance
                -- Raycast down from noclip point to find ground (don't go through floor)
                local downRay = RaycastParams.new()
                downRay.FilterDescendantsInstances = { StackSphere }
                downRay.FilterType = Enum.RaycastFilterType.Exclude
                local groundResult = workspace:Raycast(noclipPos, Vector3.new(0, -500, 0), downRay)
                if groundResult then
                    StackSphere.Position = groundResult.Position
                else
                    StackSphere.Position = noclipPos
                end
            elseif mouse.Hit then
                StackSphere.Position = mouse.Hit.Position
            end
        end
    elseif StackSphere then
        StackSphere:Destroy()
        StackSphere = nil
    end

    UpdatePathVisuals()
end)

