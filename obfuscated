local function WaitForEquippedToInclude(towerName, timeoutSec)
    timeoutSec = timeoutSec or 8
    local deadline = os.clock() + timeoutSec
    while os.clock() < deadline do
        local list = GetEquippedListFromState()
        for _, name in ipairs(list) do
            if type(name) == "string" and name:lower() == towerName:lower() then
                return true
            end
        end
        task.wait(0.1)
    end
    return false
end

function TDS:Loadout(...)
    if GameState ~= "GAME" then
        return false
    end

    local towers = {...}
    local remote = ReplicatedStorage:WaitForChild("RemoteFunction", 10)
    if not remote then return false end
    
    local StateReplicators = ReplicatedStorage:WaitForChild("StateReplicators", 5) or ReplicatedStorage:FindFirstChild("StateReplicators")
    local CurrentlyEquipped = {}

    if StateReplicators then
        for _, folder in ipairs(StateReplicators:GetChildren()) do
            if folder.Name == "PlayerReplicator" and folder:GetAttribute("UserId") == LocalPlayer.UserId then
                local EquippedAttr = folder:GetAttribute("EquippedTowers")
                if type(EquippedAttr) == "string" then
                    local CleanedJson = EquippedAttr:match("%[.*%]")
                    if CleanedJson then
                        local DecodeSuccess, decoded = pcall(function()
                            return HttpService:JSONDecode(CleanedJson)
                        end)
                        if DecodeSuccess and type(decoded) == "table" then
                            CurrentlyEquipped = decoded
                        end
                    end
                end
                break
            end
        end
    end

    -- Unequip existing towers with longer delays so server/client stay in sync
    local maxTries = 25
    for _, CurrentTower in ipairs(CurrentlyEquipped) do
        if CurrentTower and CurrentTower ~= "" and CurrentTower ~= "None" then
            for _ = 1, maxTries do
                local ok = pcall(function()
                    remote:InvokeServer("Inventory", "Unequip", "tower", CurrentTower)
                end)
                if ok then break end
                task.wait(0.15)
            end
            task.wait(0.3)
        end
    end

    task.wait(0.4)

    -- Equip each tower and wait for state to update before continuing
    for _, TowerName in ipairs(towers) do
        local name = type(TowerName) == "string" and TowerName:gsub("^%s+", ""):gsub("%s+$", "") or tostring(TowerName)
        if name ~= "" then
            for attempt = 1, maxTries do
                local ok, err = pcall(function()
                    return remote:InvokeServer("Inventory", "Equip", "tower", name)
                end)
                if ok then
                    if Logger and type(Logger.Log) == "function" then
                        pcall(Logger.Log, Logger, "Equipped tower: " .. name)
                    end
                    WaitForEquippedToInclude(name, 4)
                    break
                end
                if attempt == maxTries then
                    error("Equip failed for '" .. name .. "': " .. tostring(err))
                end
                task.wait(0.15)
            end
            task.wait(0.35)
        end
    end

    task.wait(0.3)
    return true
end

