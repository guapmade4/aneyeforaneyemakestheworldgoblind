        local option_holder_original_parent = objects["dropdown"];
        local option_holder_original_position = dim2(0, 0, 1, 3);
        local option_holder_original_size = dim2(1, 0, 0, 110);
        function dropdown:set_open(bool)
            if bool then
                if next(dropdown.options) == nil then return end
                local visibleCount = 0
                for _, opt in pairs(dropdown.options) do
                    if opt and opt.object and (opt.object.Visible == nil or opt.object.Visible) then
                        visibleCount = visibleCount + 1
                    end
                end
                if visibleCount == 0 then return end
                for other, _ in pairs(library.open_dropdowns or {}) do
                    if other ~= dropdown and other.set_open then
                        other:set_open(false);
                    end;
                end;
                library.open_dropdowns[dropdown] = true;
            else
                if library.open_dropdowns then
                    library.open_dropdowns[dropdown] = nil;
                end;
                local opt = objects["option_holder"];
                if opt.Parent ~= option_holder_original_parent then
                    opt.Parent = option_holder_original_parent;
                    opt.Position = option_holder_original_position;
                    opt.Size = option_holder_original_size;
                end;
            end;
            self.open = bool;
            for _, instance in objects["dropdown"]:GetDescendants() do
                if not instance.ClassName:find("UI") then
                    instance.ZIndex = bool and 15 or 1;
                end;
            end;
            local opt = objects["option_holder"];
            opt.Visible = bool;
            if bool and library.holder then
                opt.Parent = library.holder;
                local drop = objects["dropdown"];
                local ap, as = drop.AbsolutePosition, drop.AbsoluteSize;
                local optionCount = 0
                for _, opt in pairs(dropdown.options) do
                    if opt and opt.object and (opt.object.Visible == nil or opt.object.Visible) then
                        optionCount = optionCount + 1
                    end
                end
                local rowHeight = 18
                local listHeight = optionCount > 0 and math.min(280, math.max(36, optionCount * rowHeight)) or 110
                local listTop = ap.Y + as.Y + 2
                local winBottom = nil
                local p = drop.Parent
                while p do
                    if p.Name == "Main_Frame" and p.AbsoluteSize.Y > 0 then
                        winBottom = p.AbsolutePosition.Y + p.AbsoluteSize.Y
                        break
                    end
                    p = p.Parent
                end
                if winBottom and listTop < winBottom then
                    local available = math.floor(winBottom - listTop - 8)
                    if available > 0 then
                        listHeight = math.min(listHeight, math.max(36, available))
                    end
                end
                dropdown._list_height = listHeight
                opt.Position = UDim2.fromOffset(ap.X, listTop);
                opt.Size = UDim2.fromOffset(as.X, listHeight);
                if not library._dropdown_position_updater then
                    library._dropdown_position_updater = run_service.RenderStepped:Connect(function()
                        for d, _ in pairs(library.open_dropdowns or {}) do
                            if d and d.update_position then pcall(d.update_position, d) end
                        end
                    end);
                end
            end;
            objects["open"].Text = bool and "-" or "+";
        end;

        function dropdown.update_position(d)
            if not d.open then return end
            local o = objects["option_holder"];
            if o.Parent ~= library.holder then return end
            local drop = objects["dropdown"];
            if not drop or not drop.Parent then return end
            local ap, as = drop.AbsolutePosition, drop.AbsoluteSize;
            local visibleCount = 0
            for _, opt in pairs(d.options) do
                if opt and opt.object and (opt.object.Visible == nil or opt.object.Visible) then
                    visibleCount = visibleCount + 1
                end
            end
            local rowHeight = 18
            local listHeight = visibleCount > 0 and math.min(280, math.max(36, visibleCount * rowHeight)) or 110
            local listTop = ap.Y + as.Y + 2
            local winBottom = nil
            local p = drop.Parent
            while p do
                if p.Name == "Main_Frame" and p.AbsoluteSize.Y > 0 then
                    winBottom = p.AbsolutePosition.Y + p.AbsoluteSize.Y
                    break
                end
                p = p.Parent
            end
            if winBottom and listTop < winBottom then
                local available = math.floor(winBottom - listTop - 8)
                if available > 0 and listHeight > available then
                    listHeight = math.max(36, available)
                end
            end
            o.Position = UDim2.fromOffset(ap.X, listTop);
            o.Size = UDim2.fromOffset(as.X, listHeight);
        end;

