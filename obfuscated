        task.wait(2)
        ApplyGatlingHook()
    end)
end

-- Built-in Anti-AFK (runs in background, no UI)
task.defer(function()
    if getgenv().AntiAFKActive then return end
    repeat task.wait() until game:IsLoaded() and game.Players and game.Players.LocalPlayer and game.Players.LocalPlayer.Character
    getgenv().AntiAFKActive = true
    local VirtualUser = game:GetService("VirtualUser")
    local LocalPlayer = game.Players.LocalPlayer
    LocalPlayer.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
end)

-- Support for strategy scripts: TDS is in _G.TDS and shared.TDSTable. You can run a strategy in a
-- second script (e.g. load Original.lua first, then run your strategy that calls TDS:Loadout(...), etc.)
-- or save your strategy to tds/strats/run.lua and it will run automatically after the script loads.
task.defer(function()
    if not readfile or not isfile or not makefolder or not isfolder then return end
    local stratsFolder = TDSFolder .. "/strats"
    if not isfolder(TDSFolder) then makefolder(TDSFolder) end
    if not isfolder(stratsFolder) then return end
    local runPath = stratsFolder .. "/run.lua"
    if not isfile(runPath) then return end
    local ok, code = pcall(readfile, runPath)
    if not ok or not code or code == "" then return end
    local fn, err = loadstring(code, "tds/strats/run.lua")
    if not fn then return end
    task.spawn(function()
        -- Wait for TDS to be available so strategy never calls nil
        while not _G.TDS and not shared.TDSTable do task.wait() end
        local TDS = _G.TDS or shared.TDSTable
        if TDS then pcall(fn) end
    end)
end)

return TDS
