    local function UpdateMiscTowers()
        local equipped = GetEquippedTowers()
        local equippedSet = {}
        for _, name in ipairs(equipped) do
            if name and name ~= "None" then
                equippedSet[name] = true
            end
        end
        -- Remove labels for towers no longer equipped
        for name, lbl in pairs(miscLabels or {}) do
            if not equippedSet[name] and lbl and lbl.Parent then
                lbl:Destroy()
                miscLabels[name] = nil
            end
        end
        -- Ensure label for each equipped tower (create if missing)
        local theme = library.theme
        local fontSize = library.font_size or 12
        local fontFace = library.font_face
        for order, name in ipairs(equipped) do
            if not name or name == "None" then
            elseif miscInner and (not miscLabels[name] or not miscLabels[name].Parent) then
                local lbl = Instance.new("TextLabel")
                lbl.Size = UDim2.new(1, -4, 0, 14)
                lbl.BackgroundTransparency = 1
                lbl.Text = name .. ": 0"
                lbl.TextColor3 = theme.Text
                lbl.TextSize = fontSize
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                lbl.LayoutOrder = order - 1
                if fontFace then pcall(function() lbl.FontFace = fontFace end) end
                lbl.Parent = miscInner
                miscLabels[name] = lbl
            elseif miscLabels[name] then
                miscLabels[name].LayoutOrder = order - 1
            end
        end
        -- Count placed towers (only for equipped names)
        local counts = {}
        for name in pairs(equippedSet) do
            counts[name] = 0
        end
        local folder = workspace:FindFirstChild("Towers")
        if folder then
            for _, tower in ipairs(folder:GetChildren()) do
                local rep = tower:FindFirstChild("TowerReplicator")
                if rep and rep:GetAttribute("OwnerId") == LocalPlayer.UserId then
                    local name = rep:GetAttribute("Name") or tower.Name
                    if counts[name] ~= nil then
                        counts[name] = counts[name] + 1
                    end
                end
            end
        end
        for name, lbl in pairs(miscLabels or {}) do
            if lbl and lbl.Parent then
