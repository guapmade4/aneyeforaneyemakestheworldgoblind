-- // Recorder tab: left = Recorder (place/upgrade/sell), right = >.< (strategy log: map, equipped, etc.)
local Logger
do
    local RecorderTab = Window:Tab({Title = "Recorder", Icon = "camera"})
    Logger = RecorderTab:CreateLogger({Title = ">.<", Size = UDim2.new(0, 330, 0, 300), Side = "Right", HorizontalScroll = true})
    local Recorder = RecorderTab:CreateLogger({Title = "Recorder", Size = UDim2.new(0, 330, 0, 230), Side = "Left", HorizontalScroll = true})

    -- Log map and equipped troops to >.< when in game
    task.defer(function()
        if not Logger or type(Logger.Log) ~= "function" then return end
        local function tryLogMapAndEquipped()
            if not PlayerGui:FindFirstChild("ReactUniversalHotbar") then return false end
            local State = ReplicatedStorage:FindFirstChild("State")
            local mapName = "?"
            local difficulty = "?"
            if State then
                pcall(function() mapName = State.Map and State.Map.Value or mapName end)
                pcall(function() difficulty = State.Difficulty and State.Difficulty.Value or difficulty end)
            end
            local equipped = GetEquippedTowers()
            local equippedStr = type(equipped) == "table" and table.concat(equipped, ", ") or tostring(equipped)
            Logger:Log("Map: " .. tostring(mapName))
            Logger:Log("Difficulty: " .. tostring(difficulty))
            Logger:Log("Equipped: " .. equippedStr)
            return true
        end
        for _ = 1, 60 do
            if tryLogMapAndEquipped() then break end
            task.wait(1)
        end
    end)
    local record_strat = false
    local recorded_lines = {}
    local header = ""
    local spawned_towers = {}
    local tower_count = 0

    local StratsFolder = TDSFolder .. "/strats"
    local function record_action(line)
        if not record_strat or not line then return end
        table.insert(recorded_lines, line)
        if appendfile and makefolder then
            if not isfolder(TDSFolder) then makefolder(TDSFolder) end
            if not isfolder(StratsFolder) then makefolder(StratsFolder) end
            pcall(appendfile, StratsFolder .. "/Strat.txt", line .. "\n")
        end
    end

    local function sync_towers()
        spawned_towers = {}
        tower_count = 0
        if GameState ~= "GAME" then return end
        local folder = workspace:FindFirstChild("Towers")
        if not folder then return end
        for _, tower in ipairs(folder:GetChildren()) do
            local rep = tower:FindFirstChild("TowerReplicator")
            if rep and rep:GetAttribute("OwnerId") == LocalPlayer.UserId then
                tower_count = tower_count + 1
                spawned_towers[tower] = tower_count
            end
        end
    end

    RecorderTab:Button({Title = "START", Desc = "", Callback = function()
        Recorder:Clear()
        Recorder:Log("Recorder started")
        recorded_lines = {}
        sync_towers()
        local mode = "Unknown"
        local map = "Unknown"
        local state = ReplicatedStorage:FindFirstChild("State")
        if state then
            pcall(function() mode = state.Difficulty.Value or mode end)
            pcall(function() map = state.Map.Value or map end)
        end
        local t1, t2, t3, t4, t5 = "None", "None", "None", "None", "None"
        local stateRep = ReplicatedStorage:FindFirstChild("StateReplicators")
        if stateRep then
            for _, folder in ipairs(stateRep:GetChildren()) do
                if folder.Name == "PlayerReplicator" and folder:GetAttribute("UserId") == LocalPlayer.UserId then
                    local eq = folder:GetAttribute("EquippedTowers")
                    if type(eq) == "string" then
                        local clean = eq:match("%[.*%]")
                        if clean then
                            local ok, tbl = pcall(HttpService.JSONDecode, HttpService, clean)
                            if ok and type(tbl) == "table" then
                                t1 = tbl[1] or "None"
                                t2 = tbl[2] or "None"
                                t3 = tbl[3] or "None"
                                t4 = tbl[4] or "None"
                                t5 = tbl[5] or "None"
                            end
                        end
                    end
                    break
                end
            end
        end
        header = string.format([[
TDS:Loadout("%s", "%s", "%s", "%s", "%s")
TDS:Mode("%s")
TDS:GameInfo("%s", {})

]], t1, t2, t3, t4, t5, tostring(mode), tostring(map))
        if writefile and makefolder then
            if not isfolder(TDSFolder) then makefolder(TDSFolder) end
            if not isfolder(StratsFolder) then makefolder(StratsFolder) end
            writefile(StratsFolder .. "/Strat.txt", header)
        end
        record_strat = true
        if GameState == "GAME" then
            local folder = workspace:WaitForChild("Towers", 5)
            if folder then
                folder.ChildAdded:Connect(function(tower)
                    if not record_strat then return end
                    local rep = tower:WaitForChild("TowerReplicator", 5)
                    if not rep then return end
                    if rep:GetAttribute("OwnerId") ~= LocalPlayer.UserId then return end
                    tower_count = tower_count + 1
                    local idx = tower_count
                    spawned_towers[tower] = idx
                    local name = rep:GetAttribute("Name") or tower.Name
                    local pos = rep:GetAttribute("Position")
                    local x, y, z = 0, 0, 0
                    if type(pos) == "Vector3" then
                        x, y, z = pos.X, pos.Y, pos.Z
                    else
                        local p = tower:GetPivot().Position
                        x, y, z = p.X, p.Y, p.Z
                    end
                    local cmd = string.format('TDS:Place("%s", %s, %s, %s)', name, tostring(x), tostring(y), tostring(z))
                    record_action(cmd)
                    Recorder:Log("Placed " .. name .. " (#" .. idx .. ")")
                    rep:GetAttributeChangedSignal("Upgrade"):Connect(function()
                        if not record_strat then return end
                        record_action(string.format("TDS:Upgrade(%d)", idx))
                        Recorder:Log("Upgraded #" .. idx)
                    end)
                end)
                folder.ChildRemoved:Connect(function(tower)
                    if not record_strat then return end
                    local idx = spawned_towers[tower]
                    if idx then
                        record_action(string.format("TDS:Sell(%d)", idx))
                        Recorder:Log("Sold #" .. idx)
                        spawned_towers[tower] = nil
                    end
                end)
            end
        end
        Window:Notify({Title = "Microphone", Desc = "Recording. Place/upgrade/sell towers, then click STOP.", Time = 3, Type = "normal"})
    end})

    RecorderTab:Button({Title = "STOP", Desc = "", Callback = function()
        record_strat = false
        if writefile and makefolder then
            if not isfolder(TDSFolder) then makefolder(TDSFolder) end
            if not isfolder(StratsFolder) then makefolder(StratsFolder) end
            local full = (header or "") .. table.concat(recorded_lines, "\n")
            if #full > 0 then
                writefile(StratsFolder .. "/Strat.txt", full .. "\n")
            end
        end
        Recorder:Clear()
        Recorder:Log("Strategy saved to tds/strats/Strat.txt")
        Window:Notify({Title = "Microphone", Desc = "Saved! Check tds/strats folder for Strat.txt", Time = 3, Type = "normal"})
    end})
end
-- END EMBEDDED RECORDER (Place/Upgrade/Sell + save on STOP)

