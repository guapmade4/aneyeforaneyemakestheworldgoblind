        objects["UIStroke3"] = utility.new("UIStroke", {
            Parent = objects["value"],
            Color = rgb(0, 0, 0),
            LineJoinMode = Enum.LineJoinMode.Miter
        })

        local function safe_num(n, fallback)
            if n == nil or n ~= n then return fallback or 0 end
            return n
        end
        function slider:set(value)
            local min_val = safe_num(data.min, 0)
            local max_val = safe_num(data.max, 100)
            local num = tonumber(value)
            if num == nil or num ~= num then num = min_val end
            local decimals = data.decimals
            if decimals == nil then decimals = 1 end
            local rounded = (decimals == 0) and math.floor(num + 0.5) or utility.round(num, decimals)
            if rounded ~= rounded then rounded = min_val end
            slider.value = math.clamp(rounded, min_val, max_val);
            local range = max_val - min_val
            if range < 0.0001 then range = 1 end
            local scale = math.clamp((slider.value - min_val) / range, 0, 1)
            local disp_val = safe_num(slider.value, 0)
            local disp_max = safe_num(max_val, 100)
            local suffix = data.suffix or ""
            if not data.compact then
                objects["value"].Text = string.format("%s/%s%s", tostring(disp_val), tostring(disp_max), suffix);
            else
                objects["value"].Text = string.format("%s: %s/%s%s", data.name or "", tostring(disp_val), tostring(disp_max), suffix);
            end
            if library.tweening then
                tween_service:Create(objects["indicator"], TweenInfo.new(0.09, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = dim2(scale, 0, 1, 0)}):Play();
            else
                objects["indicator"].Size = dim2(scale, 0, 1, 0);
            end
            if data.infinite and slider.value == max_val then
                objects["value"].Text = "Infinite";
            else
                objects["value"].Text = string.format("%s/%s%s", tostring(disp_val), tostring(disp_max), suffix);
            end
            if data.callback then
                data.callback(slider.value);
            end
        end;

        function slider:get()
            return slider.value;
        end;

        utility.connect(objects["real_slider"].InputBegan, function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                slider.sliding = true;
                local size_x = (input.Position.X - objects["real_slider"].AbsolutePosition.X) / objects["real_slider"].AbsoluteSize.X;
                local value = ((data.max - data.min) * size_x) + data.min;
                slider:set(value);
            end;
        end, data.name .. "real_sliderInputBegan");

        utility.connect(objects["real_slider"].InputEnded, function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                slider.sliding = false;
            end;
        end, data.name .. "real_sliderInputEnded");

        utility.connect(user_input_service.InputChanged, function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                if slider.sliding then
                    local size_x = (input.Position.X - objects["real_slider"].AbsolutePosition.X) / objects["real_slider"].AbsoluteSize.X;
                    local value = ((data.max - data.min) * size_x) + data.min;
                    slider:set(value);
                    library.dragging = nil;
                end;
            end;
        end, data.name .. "inputChanged_");

        slider:set(data.default);

        function slider:SetMax(m)
            local n = tonumber(m)
            if n == nil or n ~= n then return end
            data.max = n
            if data.max <= data.min then data.min = data.max - 1 end
            self:set(math.clamp(self.value, data.min, data.max))
        end
        function slider:SetMin(m)
            local n = tonumber(m)
            if n == nil or n ~= n then return end
            data.min = n
            if data.min >= data.max then data.max = data.min + 1 end
            self:set(math.clamp(self.value, data.min, data.max))
        end
        function slider:SetValue(v) self:set(v) end

        library.flags[data.flag] = slider;
        return slider, objects;
    end;

